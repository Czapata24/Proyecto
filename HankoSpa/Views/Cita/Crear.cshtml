@model CitaDTO

@{
    ViewData["Title"] = "Crear Cita";
}

<h2>Crear Nueva Cita</h2>

<form asp-action="Crear" method="post">
    <div class="form-group">
        <label>Nombre del paciente</label>
        <input asp-for="NombrePaciente" class="form-control" />
        <span asp-validation-for="NombrePaciente" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Fecha de la cita</label>
        <input asp-for="FechaCita" class="form-control" type="date" />
        <span asp-validation-for="FechaCita" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Seleccione Servicios</label><br />
        @foreach (var servicio in ViewBag.Servicios as List<CitasServiciosDTO>)
        {
            <div class="form-check">
                <input type="checkbox" class="form-check-input" name="ServiciosSeleccionados" value="@servicio.Id" />
                <label class="form-check-label">@servicio.NombreServicio (@servicio.Precio.ToString("C"))</label>
            </div>
        }
        <span asp-validation-for="ServiciosSeleccionados" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
