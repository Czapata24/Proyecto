@model List<Models.Cita>

@{
    ViewData["Title"] = "Citas Registradas";
}

<h2>Lista de Citas</h2>

<table class="table">
    <thead>
        <tr>
            <th>Paciente</th>
            <th>Fecha</th>
            <th>Servicios</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cita in Model)
        {
            <tr>
                <td>@cita.Paciente</td>
                <td>@cita.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <ul>
                        @foreach (var servicio in cita.Servicios)
                        {
                            <li>@servicio.Nombre (@servicio.Precio.ToString("C"))</li>
                        }
                    </ul>
                </td>
            </tr>
        }
    </tbody>
</table>
