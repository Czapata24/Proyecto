@model DTOs.CitaDTO

@{
    ViewData["Title"] = "Crear Cita";
    var servicios = ViewBag.Servicios as List<Models.Citas_Servicios>;
}

<h2>Crear Nueva Cita</h2>

<form asp-action="Crear" method="post">
    <div class="form-group">
        <label asp-for="Paciente"></label>
        <input asp-for="Paciente" class="form-control" />
        <span asp-validation-for="Paciente" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Fecha"></label>
        <input asp-for="Fecha" type="datetime-local" class="form-control" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Servicios</label><br />
        @foreach (var servicio in servicios)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="ServiciosIds" value="@servicio.Id" />
                <label class="form-check-label">@servicio.Nombre (@servicio.Precio.ToString("C"))</label>
            </div>
        }
        <span asp-validation-for="ServiciosIds" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar Cita</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
